# ===== Frontend (public, browser-accessible) =====
# API is same-origin (Next.js serves both UI and /api routes) — no API URL needed.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ===== Database =====
DATABASE_URL=

# ===== Runtime =====
NODE_ENV=development

# ===== JWT =====
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES=7d

# ===== Google OAuth (server-side secret) =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Email (Nodemailer / Gmail) =====
EMAIL_USER=
EMAIL_PASS=
EMAIL_SERVICE=gmail

# ===== AWS S3 =====
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=
AWS_BUCKET_NAME=

# ===== Redis =====
USE_CLOUD_REDIS=true
CLOUD_REDIS_URL=
